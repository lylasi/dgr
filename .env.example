# PEN子打工人环境变量示例。复制后必须填写必填项：
# - 非 Docker：cp .env.example .env.local
# - Docker Compose：cp .env.example .env
# 不要在此示例文件或任何会提交到 Git 的文件中填写真实密码。

# 必填。唯一管理员的登录密码。修改并重启后，旧管理员登录会失效。
ADMIN_PASSWORD=

# 必填。用于签名登录 Cookie，至少 32 个字符；生产环境建议使用随机值。
# 可用 openssl rand -hex 32 生成。修改后所有设备都需要重新登录。
SESSION_SECRET=

# 应用监听端口。非 Docker 的 npm run dev/npm start 和 Docker 端口映射都会使用它。
PORT=3000

# 业务日期与每日奖励使用的 IANA 时区。
APP_TIMEZONE=Asia/Shanghai

# 非 Docker 使用的 SQLite 路径；相对路径从项目根目录计算。
# Docker Compose 中固定为容器内 /app/data/pen-worker.db，由 DATA_DIR 映射到宿主机。
DATABASE_PATH=./data/pen-worker.db

# 登录 Cookie 保留天数，必须是正数；无效值会回退到 180 天。
SESSION_MAX_AGE_DAYS=180

# 仅在网站通过 HTTPS 访问时设为 true；局域网 HTTP 访问应保持 false。
COOKIE_SECURE=false

# 仅供 next dev 使用。允许局域网开发访问的主机名或 IP；多个值用英文逗号分隔。
# 正式的 npm start 和 Docker 生产启动不需要设置。
ALLOWED_DEV_ORIGINS=

# 仅供 Docker Compose 使用。宿主机数据目录，会绑定到容器的 /app/data。
# 可以使用绝对路径；默认 ./data，数据库最终位于 DATA_DIR/pen-worker.db。
DATA_DIR=./data
